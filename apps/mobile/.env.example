# Copy to .env in this folder (or set EAS env for release builds). Vercel env does NOT
# apply to the Expo app — EXPO_PUBLIC_* must be present when you build/run the mobile app.
# Same Supabase project as the Next app (.env.local).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# HTTPS origin of the Creatix deployment (no trailing slash).
EXPO_PUBLIC_API_URL=https://www.circeetvenus.com

# Optional — after `eas init`, paste the UUID here so `extra.eas.projectId` is set for push (Expo).
# EXPO_PUBLIC_EAS_PROJECT_ID=
